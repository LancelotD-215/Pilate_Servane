# ─────────────────────────────────────────────
#  .gitignore — Application Flask "Gestion Pilate"
# ─────────────────────────────────────────────

# --- Python : bytecode & cache ---
__pycache__/
*.py[cod]
*$py.class

# --- Environnements virtuels ---
.venv/
venv/
env/
ENV/

# --- Bases de données SQLite (données de production / locales) ---
# /!\ Ne jamais versionner les .db : ils contiennent les données clients
*.db
*.sqlite
*.sqlite3

# --- Variables d'environnement & secrets ---
.env
.env.*
*.key

# --- Données personnelles (RGPD) ---
# Exports et listes clients : ne pas versionner
data/*.csv

# --- Outils de développement local ---
ngrok.exe
*.log

# --- IDE / Éditeurs ---
.vscode/
.idea/
*.swp

# --- Systèmes d'exploitation ---
.DS_Store
Thumbs.db
desktop.ini

# --- Packaging / build (si un jour nécessaire) ---
build/
dist/
*.egg-info/
